#!/bin/bash
# pre-push hook — Radiant Play maintainer safety net
#
# Fires on every `git push`. If pushing to main, checks whether
# platformVersion.ts was modified in the commits being pushed.
# Prints a reminder if not — but never hard-blocks (use --no-verify to bypass).
#
# Install once: bash scripts/install-maintainer-hooks.sh

PLATFORM_VERSION_FILE="src/data/platformVersion.ts"
RELEASE_SCRIPT="scripts/release.sh"

# Read push target from git's stdin (format: <local-ref> <local-sha> <remote-ref> <remote-sha>)
while read local_ref local_sha remote_ref remote_sha; do
  # Only care about pushes to main
  if [[ "$remote_ref" != "refs/heads/main" ]]; then
    exit 0
  fi

  # Check if platformVersion.ts is modified in the commits being pushed
  if git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null | grep -q "$PLATFORM_VERSION_FILE"; then
    echo "✓ platformVersion.ts updated — release looks good. Pushing to main."
    exit 0
  fi

  # Not updated — print reminder, but allow push
  echo ""
  echo "⚠️  Pushing to main without a version bump."
  echo "   platformVersion.ts was not changed in these commits."
  echo ""
  echo "   If this is a release, run: bash $RELEASE_SCRIPT"
  echo "   To push anyway:           git push --no-verify"
  echo ""
  # Exit 0 = soft reminder, push still proceeds
  exit 0
done

exit 0
